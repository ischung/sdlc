{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh issue create*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/add-new-issue-to-kanban.sh",
            "timeout": 30,
            "statusMessage": "SDLC: 새 이슈를 칸반 보드에 자동 추가 중…"
          }
        ]
      }
    ]
  }
}
